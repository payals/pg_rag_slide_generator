# =============================================================================
# Postgres-First AI Slide Generator - Environment Configuration
# =============================================================================
# Only secrets, connection strings, and local paths belong here.
# All operational config (thresholds, model names, limits, toggles)
# lives in the Postgres `config` table — see migration 013.

# -----------------------------------------------------------------------------
# Secrets
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_USER=

# -----------------------------------------------------------------------------
# Connection Strings
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/slidegen

# -----------------------------------------------------------------------------
# Infrastructure / Paths
# -----------------------------------------------------------------------------
SSL_VERIFY=false
# HF_HOME=./.hf_cache
IMAGE_CONTENT_DIR=content/images

# Optional: directory containing personal notes (markdown files) to ingest
# as high-trust tier1 content. Files are auto-discovered by subdirectory:
#   <dir>/blogs/*          → doc_type=blog
#   <dir>/learning/*       → doc_type=note  (case-insensitive)
#   <dir>/*.md             → doc_type=note
# PERSONAL_NOTES_DIR=./my_notes

# -----------------------------------------------------------------------------
# Kafka (Automated Ingestion)
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=content.changes

# -----------------------------------------------------------------------------
# Optional: LangSmith Tracing (Development Only)
# -----------------------------------------------------------------------------
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-api-key
# LANGCHAIN_PROJECT=slidegen-dev
