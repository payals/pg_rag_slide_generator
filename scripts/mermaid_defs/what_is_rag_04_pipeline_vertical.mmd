flowchart TD
    Q["🔍 User Query"] --> EMB["1️⃣ Embed Query<br/>text → vector(1536)"]
    EMB --> SEARCH["2️⃣ Hybrid Search<br/>(Postgres: pgvector + pg_trgm + tsvector)"]
    SEARCH --> RETRIEVE["3️⃣ Retrieve Chunks<br/>(Postgres: top-K by RRF score)"]
    RETRIEVE --> RERANK["4️⃣ Rerank<br/>cross-encoder scoring"]
    RERANK --> CONTEXT["5️⃣ Build Context<br/>format chunks into prompt"]
    CONTEXT --> LLM["6️⃣ LLM Generate<br/>GPT-4 with grounding"]
    LLM --> OUTPUT["7️⃣ Cited Output<br/>response with source refs"]

